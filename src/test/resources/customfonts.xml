<?xml version="1.0" encoding="UTF-8"?>

<fontFamilies>

  <fontFamily name="Arimo">
    <normal>ch/unibas/medizin/dynamicreports/test/fonts/Arimo-Regular.ttf</normal>
    <bold>ch/unibas/medizin/dynamicreports/test/fonts/Arimo-Bold.ttf</bold>
    <italic>ch/unibas/medizin/dynamicreports/test/fonts/Arimo-Italic.ttf</italic>
    <pdfEncoding>Identity-H</pdfEncoding>
    <pdfEmbedded>true</pdfEmbedded>
  </fontFamily>

  <!--
    FreeUniversal in all four variants, as the fonts examples (FontsReport, DefaultFontReport)
    require. The TTFs live under the examples resources copied into src/test/resources.
  -->
  <fontFamily name="FreeUniversal">
    <normal>ch/unibas/medizin/dynamicreports/examples/fonts/FreeUniversal-Regular.ttf</normal>
    <bold>ch/unibas/medizin/dynamicreports/examples/fonts/FreeUniversal-Bold.ttf</bold>
    <italic>ch/unibas/medizin/dynamicreports/examples/fonts/FreeUniversal-Italic.ttf</italic>
    <boldItalic>ch/unibas/medizin/dynamicreports/examples/fonts/FreeUniversal-BoldItalic.ttf</boldItalic>
    <pdfEncoding>Cp1252</pdfEncoding>
    <pdfEmbedded>true</pdfEmbedded>
  </fontFamily>

</fontFamilies>
